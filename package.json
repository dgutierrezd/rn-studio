{
  "name": "rn-studio",
  "version": "0.1.0",
  "description": "Live UI editor for React Native — inspect and edit components directly in your emulator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "babel-plugin",
    "bin",
    "README.md"
  ],
  "bin": {
    "rn-studio-server": "./bin/rn-studio-server.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./babel-plugin": "./babel-plugin/index.js"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.70",
    "react-native-gesture-handler": ">=2.0",
    "react-native-reanimated": ">=3.0",
    "react-native-haptic-feedback": ">=2.0",
    "react-native-safe-area-context": ">=4.0"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": { "optional": true },
    "react-native-reanimated": { "optional": true },
    "react-native-haptic-feedback": { "optional": true },
    "react-native-safe-area-context": { "optional": true }
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "recast": "^0.23.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/ws": "^8.0.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0"
  },
  "keywords": [
    "react-native",
    "devtools",
    "ui-editor",
    "live-edit",
    "inspector",
    "ast",
    "babel"
  ],
  "license": "MIT",
  "author": "rn-studio contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/rn-studio/rn-studio.git"
  }
}
